<section class="custom-banner">
  <div class="banner-content">
    <h1>{{ section.settings.heading }}</h1>
    <p>{{ section.settings.subtext }}</p>

    <a href="{{ section.settings.button_link }}" class="banner-btn">
      {{ section.settings.button_text }}
    </a>
  </div>
</section>

<style>
.custom-banner {
  background: #f5f5f5;
  padding: 120px 60px;
}

.banner-content {
  max-width: 600px;
}

.banner-content h1 {
  font-size: 48px;
  font-weight: 600;
  margin-bottom: 15px;
}

.banner-content p {
  font-size: 16px;
  color: #555;
  margin-bottom: 25px;
}

.banner-btn {
  display: inline-block;
  padding: 14px 28px;
  background: black;
  color: white;
  text-decoration: none;
  transition: 0.3s ease;
}

.banner-btn:hover {
  transform: translateX(5px);
}

/* MOBILE */
@media (max-width: 768px) {
  .custom-banner {
    padding: 80px 20px;
  }

  .banner-content h1 {
    font-size: 32px;
  }
}
</style>

{% schema %}
{
  "name": "Custom Banner",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "The Gift Guide"
    },
    {
      "type": "textarea",
      "id": "subtext",
      "label": "Sub Text",
      "default": "Discover joy with our exclusive collection."
    },
    {
      "type": "text",
      "id": "button_text",
      "label": "Button Text",
      "default": "SHOP NOW"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button Link"
    }
  ],
  "presets": [
    {
      "name": "Custom Banner"
    }
  ]
}
{% endschema %}